<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="using:MarkMello.Presentation.Localization"
             x:Class="MarkMello.Presentation.App"
             RequestedThemeVariant="Default">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://MarkMello.Presentation/Themes/Controls.axaml" />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://MarkMello.Presentation/Themes/Colors.axaml" />
        <ResourceInclude Source="avares://MarkMello.Presentation/Themes/Typography.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <localization:LocalizationService x:Key="Localization" />
    </ResourceDictionary>
  </Application.Resources>

</Application>
