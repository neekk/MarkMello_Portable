<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Ghost button: полупрозрачная кнопка для top bar и welcome actions -->
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>
  <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
  </Style>


  <Style Selector="Button.topbar-ghost">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.topbar-ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pointerover Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:pointerover Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pointerover Line">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:pointerover Line">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pressed Path">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:checked Path">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pressed Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:checked Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="Button.topbar-ghost:pressed Line">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-ghost:checked Line">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>

  <Style Selector="ToggleButton.topbar-action">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="Height" Value="28" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="MinWidth" Value="74" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:pointerover Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:pointerover TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:checked Path">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:checked Ellipse">
    <Setter Property="Stroke" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:checked TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.topbar-action:disabled">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <!-- Title bar buttons (Win-style: Min / Max / Close) -->
  <Style Selector="Button.titlebar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource MmTitleBarTextBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
  </Style>
  <Style Selector="Button.titlebar:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceHoverBrush}" />
  </Style>
  <Style Selector="Button.titlebar.close:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#E81123" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>

  <!-- Welcome primary / secondary buttons -->
  <Style Selector="Button.welcome-primary">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmBackgroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.welcome-primary:pointerover /template/ ContentPresenter">
    <Setter Property="Opacity" Value="0.85" />
  </Style>

  <Style Selector="Button.welcome-secondary">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.welcome-secondary:pointerover /template/ ContentPresenter">
    <Setter Property="TextElement.Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmTextSoftBrush}" />
  </Style>
  <Style Selector="Button.welcome-secondary:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <!-- Keyboard hint pill -->
  <Style Selector="Border.kbd">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="5,1" />
    <Setter Property="MinHeight" Value="14" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.kbd TextBlock">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="LineHeight" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.mm-settings-panel">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BoxShadow" Value="0 12 40 -8 #383C2814" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="RenderTransformOrigin" Value="100%,0%" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="RenderTransform" Value="translate(0px,-6px) scale(0.96)" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.22" />
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.mm-settings-panel.mm-popover-left">
    <Setter Property="RenderTransformOrigin" Value="0%,0%" />
  </Style>
  <Style Selector="Border.mm-settings-panel.mm-popover-right">
    <Setter Property="RenderTransformOrigin" Value="100%,0%" />
  </Style>
  <Style Selector="Window.mm-reading-settings-open Border.mm-settings-panel.mm-reading-panel">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
    <Setter Property="RenderTransform" Value="translate(0px,0px) scale(1)" />
  </Style>
  <Style Selector="Window.mm-app-menu-open Border.mm-settings-panel.mm-app-menu-panel">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
    <Setter Property="RenderTransform" Value="translate(0px,0px) scale(1)" />
  </Style>
  <Style Selector="Window.mm-app-settings-open Border.mm-settings-panel.mm-app-settings-panel">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
    <Setter Property="RenderTransform" Value="translate(0px,0px) scale(1)" />
  </Style>
  <Style Selector="Window.mm-app-about-open Border.mm-settings-panel.mm-app-about-panel">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="IsHitTestVisible" Value="True" />
    <Setter Property="RenderTransform" Value="translate(0px,0px) scale(1)" />
  </Style>

  <Style Selector="Border.mm-settings-head-shell">
    <Setter Property="Padding" Value="18,14,18,10" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="TextBlock.mm-settings-title">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="LetterSpacing" Value="1" />
  </Style>

  <Style Selector="Button.mm-settings-close">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.mm-settings-close:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
  </Style>

  <Style Selector="Button.mm-settings-close:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="Border.mm-settings-body-shell">
    <Setter Property="Padding" Value="12,8,12,14" />
  </Style>

  <Style Selector="Border.mm-setting-row">
    <Setter Property="Padding" Value="6,10" />
  </Style>
  <Style Selector="Line.mm-setting-divider">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Stretch" Value="Fill" />
    <Setter Property="Stroke" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="StrokeThickness" Value="1" />
    <Setter Property="StrokeDashArray" Value="2,2" />
  </Style>

  <Style Selector="TextBlock.mm-setting-label">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="TextBlock.mm-setting-hint">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBlock.mm-setting-body">
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.mm-setting-meta">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource MmDocumentMonoFontFamily}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.mm-menu-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.mm-menu-item /template/ ContentPresenter">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.mm-menu-item:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
  </Style>
  <Style Selector="Button.mm-menu-item:disabled">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <Style Selector="Button.mm-inline-link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.mm-inline-link /template/ ContentPresenter">
    <Setter Property="TextBlock.TextDecorations" Value="Underline" />
  </Style>
  <Style Selector="Button.mm-inline-link:pointerover /template/ ContentPresenter">
    <Setter Property="TextElement.Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

    <Style Selector="Border.mm-segmented">
      <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

  <Style Selector="ToggleButton.mm-segmented-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Foreground"
                         Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item /template/ ContentPresenter">
    <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background"
                         Duration="0:0:0.12" />
        <BoxShadowsTransition Property="BoxShadow"
                              Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:checked">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:checked TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BoxShadow" Value="0 1 2 0 #0D000000" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BoxShadow" Value="0 1 2 0 #0D000000" />
  </Style>
  <Style Selector="ToggleButton.mm-segmented-item:checked:pointerover TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="ComboBox.mm-language-select">
    <Setter Property="Width" Value="132" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="ComboBox.mm-language-select:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>
  <Style Selector="ComboBox.mm-language-select:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="ComboBox.mm-language-select TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
  </Style>
  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
  </Style>

  <Style Selector="Slider.mm-settings-slider">
    <Setter Property="Width" Value="130" />
    <Setter Property="Height" Value="18" />
    <Setter Property="MinHeight" Value="18" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid Height="{TemplateBinding Height}"
              MinHeight="{TemplateBinding MinHeight}"
              ClipToBounds="False">
          <Border Height="2"
                  Background="{TemplateBinding Background}"
                  CornerRadius="1"
                  VerticalAlignment="Center" />
          <Track Name="PART_Track"
                 Minimum="{TemplateBinding Minimum}"
                 Maximum="{TemplateBinding Maximum}"
                 Value="{TemplateBinding Value}"
                 Orientation="{TemplateBinding Orientation}"
                 IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
            <Track.DecreaseButton>
              <RepeatButton Name="PART_DecreaseButton"
                            Classes="mm-settings-slider-hitarea" />
            </Track.DecreaseButton>
            <Track.Thumb>
              <Thumb Classes="mm-settings-slider-thumb" />
            </Track.Thumb>
            <Track.IncreaseButton>
              <RepeatButton Name="PART_IncreaseButton"
                            Classes="mm-settings-slider-hitarea" />
            </Track.IncreaseButton>
          </Track>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="RepeatButton.mm-settings-slider-hitarea">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Thumb.mm-settings-slider-thumb">
    <Setter Property="Width" Value="14" />
    <Setter Property="Height" Value="14" />
    <Setter Property="MinWidth" Value="14" />
    <Setter Property="MinHeight" Value="14" />
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmAccentBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    <Setter Property="RenderTransform" Value="scale(1)" />
    <Setter Property="Transitions">
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform"
                                       Duration="0:0:0.12" />
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="7" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Thumb.mm-settings-slider-thumb:pointerover">
    <Setter Property="RenderTransform" Value="scale(1.15)" />
  </Style>

  <Style Selector="TextBlock.mm-slider-value">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource MmDocumentMonoFontFamily}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="TextAlignment" Value="Right" />
  </Style>

  <Style Selector="Border.mm-editor-pane">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="MinWidth" Value="280" />
  </Style>

  <Style Selector="Border.mm-editor-toolbar">
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Button.mm-editor-toolbar-button">
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="24" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.mm-editor-toolbar-button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
  </Style>
  <Style Selector="Button.mm-editor-toolbar-button:pointerover Path">
    <Setter Property="Stroke" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="Border.mm-editor-toolbar-separator">
    <Setter Property="Width" Value="1" />
    <Setter Property="Height" Value="14" />
    <Setter Property="Margin" Value="4,0" />
    <Setter Property="Background" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.mm-editor-toolbar-label">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="LetterSpacing" Value="0.5" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,6,0" />
  </Style>

  <Style Selector="Border.mm-editor-status-shell">
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Background" Value="{DynamicResource MmBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <Style Selector="TextBlock.mm-editor-status-text">
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBox.mm-editor-textarea">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource MmDocumentMonoFontFamily}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="LineHeight" Value="23.8" />
    <Setter Property="CaretBrush" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>
  <Style Selector="TextBox.mm-editor-textarea /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="TextBox.mm-editor-textarea:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="TextBox.mm-editor-textarea:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="TextBox.mm-editor-textarea /template/ TextPresenter#PART_TextPresenter">
    <Setter Property="Margin" Value="36,28,36,28" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="GridSplitter.mm-editor-splitter">
    <Setter Property="Width" Value="9" />
    <Setter Property="Margin" Value="-4,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Cursor" Value="SizeWestEast" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid Background="Transparent">
          <Border Width="1"
                  HorizontalAlignment="Center"
                  Background="{DynamicResource MmBorderBrush}" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="GridSplitter.mm-editor-splitter:pointerover /template/ Border">
    <Setter Property="Background" Value="{DynamicResource MmAccentBrush}" />
  </Style>
  <Style Selector="GridSplitter.mm-editor-splitter.dragging /template/ Border">
    <Setter Property="Background" Value="{DynamicResource MmAccentBrush}" />
  </Style>

  <Style Selector="Border.mm-dialog-card">
    <Setter Property="Padding" Value="22,20" />
    <Setter Property="Background" Value="{DynamicResource MmElevatedBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BoxShadow" Value="0 16 48 -10 #25000033" />
  </Style>

  <Style Selector="TextBlock.mm-dialog-title">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource MmDocumentSansFontFamily}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="15" />
  </Style>

  <Style Selector="TextBlock.mm-dialog-body">
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Margin" Value="0,10,0,0" />
  </Style>

  <Style Selector="Border.mm-dialog-error-shell">
    <Setter Property="Background" Value="{DynamicResource MmAccentSoftBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,12,0,0" />
  </Style>

  <Style Selector="TextBlock.mm-dialog-error">
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="Button.mm-dialog-primary">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmBackgroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.mm-dialog-primary:pointerover /template/ ContentPresenter">
    <Setter Property="Opacity" Value="0.85" />
  </Style>

  <Style Selector="Button.mm-dialog-secondary">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.mm-dialog-secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="TextBlock.mm-md-heading">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="SelectableTextBlock.mm-md-heading">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.mm-md-paragraph">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="SelectableTextBlock.mm-md-paragraph">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.mm-md-list-bullet">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextSoftBrush}" />
  </Style>

  <Style Selector="Border.mm-md-quote">
    <Setter Property="Margin" Value="0,0,0,20" />
    <Setter Property="Padding" Value="20,4,0,4" />
    <Setter Property="BorderThickness" Value="2,0,0,0" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmQuoteBarBrush}" />
  </Style>

  <Style Selector="Border.mm-md-hr">
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="{DynamicResource MmBorderBrush}" />
  </Style>

  <Style Selector="Border.mm-md-codeblock">
    <Setter Property="Margin" Value="0,0,0,22" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmCodeBorderBrush}" />
    <Setter Property="Background" Value="{DynamicResource MmCodeBackgroundBrush}" />
  </Style>

  <Style Selector="TextBlock.mm-md-code-info">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource MmDocumentSansFontFamily}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Margin" Value="0,0,0,4" />
  </Style>

  <Style Selector="TextBlock.mm-md-codeblock-text">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="SelectableTextBlock.mm-md-codeblock-text">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="Border.mm-md-table">
    <!--
      Border-collapse model matching MarkMelloDesign/styles.css `.mm-table`:
      no outer frame, no rounded corners. Visual structure is expressed
      purely through per-cell bottom borders below.
    -->
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <Style Selector="Border.mm-md-table-header-cell">
    <Setter Property="Padding" Value="14,10" />
    <!-- Stronger divider directly under the header row, like `.mm-table th` border-bottom. -->
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
  </Style>

  <Style Selector="Border.mm-md-table-cell">
    <Setter Property="Padding" Value="14,10" />
    <!-- Soft divider between data rows, like `.mm-table td` border-bottom. -->
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderSoftBrush}" />
  </Style>

  <!-- Bottom row: no trailing divider. -->
  <Style Selector="Border.mm-md-table-cell.mm-md-table-cell-last">
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBlock.mm-md-table-header">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="SelectableTextBlock.mm-md-table-header">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.mm-md-table-text">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="SelectableTextBlock.mm-md-table-text">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="HyperlinkButton.mm-md-link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="TextBlock.mm-md-link-text">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
    <Setter Property="TextDecorations" Value="Underline" />
  </Style>

  <Style Selector="HyperlinkButton.mm-md-link:pointerover TextBlock.mm-md-link-text">
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="Underline.mm-md-link-fallback">
    <Setter Property="Foreground" Value="{DynamicResource MmAccentBrush}" />
  </Style>

  <Style Selector="Span.mm-md-code-inline">
    <Setter Property="Background" Value="{DynamicResource MmCodeBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource MmTextBrush}" />
  </Style>

  <Style Selector="Border.mm-md-image-placeholder">
    <Setter Property="BorderBrush" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="{DynamicResource MmSurfaceBrush}" />
  </Style>

  <Style Selector="TextBlock.mm-md-image-caption">
    <Setter Property="Foreground" Value="{DynamicResource MmTextFaintBrush}" />
  </Style>

</Styles>
