<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MarkMello.Presentation.ViewModels"
        xmlns:views="using:MarkMello.Presentation.Views"
        mc:Ignorable="d"
        x:CompileBindings="False"
        x:Class="MarkMello.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="840"
        MinWidth="640" MinHeight="480"
        Title="{Binding WindowTitle}"
        Icon="/Assets/Icons/markmello.ico"
        Background="{DynamicResource MmBackgroundBrush}"
        DragDrop.AllowDrop="True"
        UseLayoutRounding="True">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:MainWindowViewModel">
      <views:ViewerView />
    </DataTemplate>
    <DataTemplate DataType="vm:EditorSessionViewModel">
      <views:EditWorkspaceView />
    </DataTemplate>
  </Window.DataTemplates>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateNewDocumentCommand}" />
    <KeyBinding Gesture="Cmd+N" Command="{Binding CreateNewDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Cmd+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ToggleEditModeCommand}" />
    <KeyBinding Gesture="Cmd+E" Command="{Binding ToggleEditModeCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
    <KeyBinding Gesture="Cmd+S" Command="{Binding SaveCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="Cmd+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="F5" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Cmd+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding ClearErrorCommand}" />
  </Window.KeyBindings>

  <Window.Styles>
    <Style Selector="Border.mm-top-chrome">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform" Value="translate(0px,-4px)" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-top-chrome">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>
    <Style Selector="Window.mm-overlay-open Border.mm-top-chrome">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>

    <Style Selector="Border.mm-status">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.20" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-status">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Border.mm-progress">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Width" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.12" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-progress">
      <Setter Property="Opacity" Value="0.6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Height="36"
            Background="{DynamicResource MmTitleBarBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                Background="Transparent"
                PointerPressed="OnTitleBarPointerPressed">
          <DockPanel LastChildFill="True"
                     Margin="14,0,0,0"
                     VerticalAlignment="Center">
            <Ellipse DockPanel.Dock="Left"
                     Width="5" Height="5"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Fill="{DynamicResource MmAccentBrush}"
                     IsVisible="{Binding HasDocumentTitle}" />
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="12"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource MmTitleBarTextBrush}" />
          </DockPanel>
        </Border>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    IsVisible="{Binding ShowCustomTitleBar}">
          <Button Classes="titlebar"
                  Click="OnMinimizeClick"
                  ToolTip.Tip="{Binding [TitleBarMinimize], Source={StaticResource Localization}}">
            <Path Data="M0,5 L10,5"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
          <Button Classes="titlebar"
                  Click="OnMaximizeClick"
                  ToolTip.Tip="{Binding [TitleBarMaximize], Source={StaticResource Localization}}">
            <Path Data="M0,0 L10,0 L10,10 L0,10 Z"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1"
                  Fill="Transparent" />
          </Button>
          <Button Classes="titlebar close"
                  Click="OnCloseClick"
                  ToolTip.Tip="{Binding [TitleBarClose], Source={StaticResource Localization}}">
            <Path Data="M0,0 L10,10 M10,0 L0,10"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Panel Grid.Row="1"
           Name="BodyPanel">

      <views:WelcomeView IsVisible="{Binding IsWelcome}" />
      <ContentControl IsVisible="{Binding IsViewer}"
                      Content="{Binding ActiveDocumentContent}" />
      <views:LoadErrorView IsVisible="{Binding IsError}" />

      <Border Name="ReadingProgressBar"
              Classes="mm-progress"
              IsVisible="{Binding IsViewer}"
              Height="1"
              VerticalAlignment="Top"
              HorizontalAlignment="Left"
              Background="{DynamicResource MmAccentBrush}"
              IsHitTestVisible="False" />

      <Border Classes="mm-top-chrome"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="16,12,0,0">
        <ToggleButton Name="AppMenuTriggerButton"
                      Classes="topbar-ghost"
                      IsChecked="{Binding IsAppOverlayOpen, Mode=OneWay}"
                      Command="{Binding ToggleAppMenuCommand}"
                      ToolTip.Tip="{Binding [AppMenuTooltip], Source={StaticResource Localization}}">
          <Grid Width="14"
                Height="14">
            <Path Data="M2.5 4H11.5 M2.5 7H11.5 M2.5 10H11.5"
                  Stroke="{DynamicResource MmTextSoftBrush}"
                  StrokeThickness="1.5"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Fill="Transparent" />
          </Grid>
        </ToggleButton>
      </Border>

      <Border Classes="mm-top-chrome"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,12,16,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="topbar-ghost"
                  Command="{Binding CycleThemeCommand}"
                  ToolTip.Tip="{Binding NextThemeHint}">
            <Grid Width="14" Height="14">
              <Path IsVisible="{Binding ShowsMoonThemeIcon}"
                    Data="M10.5 8.5A4 4 0 1 1 5.5 3.5 3.2 3.2 0 0 0 10.5 8.5Z"
                    Stroke="{DynamicResource MmTextSoftBrush}"
                    StrokeThickness="1.5"
                    StrokeJoin="Round"
                    StrokeLineCap="Round"
                    Fill="Transparent"
                    Stretch="Uniform" />
              <Canvas IsVisible="{Binding ShowsSunThemeIcon}"
                      Width="14"
                      Height="14">
                <Ellipse Canvas.Left="4.25"
                         Canvas.Top="4.25"
                         Width="5.5"
                         Height="5.5"
                         Stroke="{DynamicResource MmTextSoftBrush}"
                         StrokeThickness="1.5"
                         Fill="Transparent" />
                <Line StartPoint="7,0.75" EndPoint="7,2.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="7,11.9" EndPoint="7,13.25"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="0.75,7" EndPoint="2.1,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="11.9,7" EndPoint="13.25,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,2.15" EndPoint="3.1,3.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,10.9" EndPoint="11.85,11.85"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,11.85" EndPoint="3.1,10.9"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,3.1" EndPoint="11.85,2.15"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
              </Canvas>
            </Grid>
          </Button>

          <ToggleButton Classes="topbar-action"
                        IsVisible="{Binding ShowsEditToggle}"
                        IsChecked="{Binding IsEditMode, Mode=OneWay}"
                        Command="{Binding ToggleEditModeCommand}"
                        ToolTip.Tip="{Binding [EditToggleTooltip], Source={StaticResource Localization}}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <Viewbox Width="12"
                       Height="12"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Grid Width="14"
                      Height="14">
                  <Path IsVisible="{Binding ShowsEditPencilIcon}"
                        Data="M2.5 11.5L5 11l6-6-2-2-6 6-.5 2.5zM8.5 3.5l2 2"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="1.5"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                  <Canvas IsVisible="{Binding ShowsReadEyeIcon}"
                          Width="14"
                          Height="14">
                    <Path Data="M1.5 7s2-4 5.5-4 5.5 4 5.5 4-2 4-5.5 4S1.5 7 1.5 7Z"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                    <Ellipse Canvas.Left="5.5"
                             Canvas.Top="5.5"
                             Width="3"
                             Height="3"
                             Stroke="{DynamicResource MmTextSoftBrush}"
                             StrokeThickness="1.5"
                             Fill="Transparent" />
                  </Canvas>
                </Grid>
              </Viewbox>
              <TextBlock Text="{Binding EditToggleLabel}"
                         FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                         FontSize="12" />
            </StackPanel>
          </ToggleButton>

          <ToggleButton Name="SettingsTriggerButton"
                        Classes="topbar-ghost"
                        IsVisible="{Binding IsViewer}"
                        Command="{Binding ToggleSettingsCommand}"
                        IsChecked="{Binding IsSettingsOpen, Mode=OneWay}"
                        ToolTip.Tip="{Binding [ReadingSettingsTooltip], Source={StaticResource Localization}}">
            <Grid Width="14"
                  Height="14">
              <Viewbox Stretch="Uniform">
                <Canvas Width="24"
                        Height="24">
                  <Path Data="M14,17 L5,17"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent" />
                  <Path Data="M19,7 L10,7"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent" />
                  <Ellipse Canvas.Left="14"
                           Canvas.Top="14"
                           Width="6"
                           Height="6"
                           Stroke="{DynamicResource MmTextSoftBrush}"
                           StrokeThickness="2"
                           Fill="Transparent" />
                  <Ellipse Canvas.Left="4"
                           Canvas.Top="4"
                           Width="6"
                           Height="6"
                           Stroke="{DynamicResource MmTextSoftBrush}"
                           StrokeThickness="2"
                           Fill="Transparent" />
                </Canvas>
              </Viewbox>
            </Grid>
          </ToggleButton>
        </StackPanel>
      </Border>

      <Border Name="AppMenuPanel"
              Classes="mm-settings-panel mm-popover-left mm-app-menu-panel"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="16,54,0,0"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="0"
                         Text="{Binding [AppMenuHeader], Source={StaticResource Localization}}" />
              <Button Grid.Column="1"
                      Classes="mm-settings-close"
                      Command="{Binding CloseOverlayCommand}"
                      ToolTip.Tip="{Binding [OverlayCloseMenu], Source={StaticResource Localization}}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Button Classes="mm-menu-item"
                      Command="{Binding OpenFileCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AppMenuOpenFileLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AppMenuOpenFileHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="Ctrl O" />
                </Grid>
              </Button>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Button Classes="mm-menu-item"
                      Command="{Binding CloseFileCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AppMenuCloseFileLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AppMenuCloseFileHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding [MetaCurrent], Source={StaticResource Localization}}" />
                </Grid>
              </Button>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Button Classes="mm-menu-item"
                      Command="{Binding OpenAppSettingsCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AppMenuSettingsLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AppMenuSettingsHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding [MetaOpen], Source={StaticResource Localization}}" />
                </Grid>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Name="AppSettingsPanel"
              Classes="mm-settings-panel mm-popover-left mm-app-settings-panel"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="16,54,0,0"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
              <Button Grid.Column="0"
                      Classes="mm-settings-close"
                      Command="{Binding ReturnToAppMenuCommand}"
                      ToolTip.Tip="{Binding [OverlayBackToMenu], Source={StaticResource Localization}}">
                <Path Data="M9.5,1.5 L2.5,5.5 L9.5,9.5"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      Fill="Transparent" />
              </Button>
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         Text="{Binding [AppSettingsHeader], Source={StaticResource Localization}}" />
              <Button Grid.Column="2"
                      Classes="mm-settings-close"
                      Command="{Binding CloseOverlayCommand}"
                      ToolTip.Tip="{Binding [OverlayCloseSettings], Source={StaticResource Localization}}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [LanguageLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [LanguageHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Classes="mm-segmented"
                          HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                Spacing="1">
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsSystemLanguageSelected}"
                                    Command="{Binding SelectSystemLanguageCommand}">
                        <TextBlock Text="{Binding [LanguageSystem], Source={StaticResource Localization}}" />
                      </ToggleButton>
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsEnglishLanguageSelected}"
                                    Command="{Binding SelectEnglishLanguageCommand}">
                        <TextBlock Text="{Binding [LanguageEnglish], Source={StaticResource Localization}}" />
                      </ToggleButton>
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsRussianLanguageSelected}"
                                    Command="{Binding SelectRussianLanguageCommand}">
                        <TextBlock Text="{Binding [LanguageRussian], Source={StaticResource Localization}}" />
                      </ToggleButton>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Border Classes="mm-setting-row">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding [UpdatesLabel], Source={StaticResource Localization}}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding [UpdatesHint], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Classes="mm-setting-meta"
                               Text="{Binding UpdateStateBadge}" />
                  </Grid>

                  <StackPanel Spacing="4">
                    <TextBlock Classes="mm-setting-label"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding UpdateStatusTitle}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="mm-setting-body"
                               Text="{Binding UpdateStatusMessage}"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <Button Classes="mm-dialog-secondary"
                            Content="{Binding CheckForUpdatesLabel}"
                            Command="{Binding CheckForUpdatesCommand}" />
                    <Button Classes="mm-dialog-primary"
                            Content="{Binding DownloadUpdateLabel}"
                            Command="{Binding DownloadUpdateCommand}"
                            IsVisible="{Binding CanDownloadAvailableUpdate}" />
                  </StackPanel>

                  <Button Classes="mm-dialog-secondary"
                          HorizontalAlignment="Left"
                          Content="{Binding DownloadedUpdateActionLabel}"
                          Command="{Binding OpenDownloadedUpdateCommand}"
                          IsVisible="{Binding CanOpenDownloadedUpdate}" />
                </StackPanel>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Button Classes="mm-menu-item"
                      Command="{Binding OpenAboutCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AboutLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AboutHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding [MetaOpen], Source={StaticResource Localization}}" />
                </Grid>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Name="AppAboutPanel"
              Classes="mm-settings-panel mm-popover-left mm-app-about-panel"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="16,54,0,0"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
              <Button Grid.Column="0"
                      Classes="mm-settings-close"
                      Command="{Binding ReturnToAppSettingsCommand}"
                      ToolTip.Tip="{Binding [OverlayBackToSettings], Source={StaticResource Localization}}">
                <Path Data="M9.5,1.5 L2.5,5.5 L9.5,9.5"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      Fill="Transparent" />
              </Button>
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         Text="{Binding [AboutHeader], Source={StaticResource Localization}}" />
              <Button Grid.Column="2"
                      Classes="mm-settings-close"
                      Command="{Binding CloseOverlayCommand}"
                      ToolTip.Tip="{Binding [OverlayCloseAbout], Source={StaticResource Localization}}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AboutVersionLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AboutVersionHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding AboutVersion}" />
                </Grid>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [AboutLicenseLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [AboutLicenseHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding AboutLicense}" />
                </Grid>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Border Classes="mm-setting-row">
                <StackPanel Spacing="8">
                  <TextBlock Classes="mm-setting-label"
                             Text="{Binding [AboutCreditsLabel], Source={StaticResource Localization}}" />
                  <WrapPanel Orientation="Horizontal"
                             ItemHeight="22">
                    <TextBlock Classes="mm-setting-body"
                               Text="{Binding [AboutCreatedByPrefix], Source={StaticResource Localization}}" />
                    <Button Classes="mm-inline-link"
                            Tag="https://ermolaev.tech"
                            Click="OnAboutLinkClick"
                            Content="Andrey Ermolaev" />
                    <TextBlock Classes="mm-setting-body"
                               Text="{Binding [AboutWith], Source={StaticResource Localization}}" />
                    <Button Classes="mm-inline-link"
                            Tag="https://skaro.dev"
                            Click="OnAboutLinkClick"
                            Content="Skaro" />
                    <TextBlock Classes="mm-setting-body"
                               Text="{Binding [AboutCreditsPeriod], Source={StaticResource Localization}}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Name="SettingsPanel"
              Classes="mm-settings-panel mm-popover-right mm-reading-panel"
              IsVisible="{Binding IsViewer}"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,54,16,0"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="0"
                         Text="{Binding [ReadingHeader], Source={StaticResource Localization}}" />
              <Button Grid.Column="1"
                      Classes="mm-settings-close"
                      Command="{Binding CloseSettingsCommand}"
                      ToolTip.Tip="{Binding [OverlayCloseSettings], Source={StaticResource Localization}}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding [ReadingFontLabel], Source={StaticResource Localization}}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding [ReadingFontHint], Source={StaticResource Localization}}" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Classes="mm-segmented"
                          HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                Spacing="1">
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsSerifFontSelected}">
                        <TextBlock Text="{Binding [ReadingFontSerif], Source={StaticResource Localization}}" />
                      </ToggleButton>
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsSansFontSelected}">
                        <TextBlock Text="{Binding [ReadingFontSans], Source={StaticResource Localization}}" />
                      </ToggleButton>
                      <ToggleButton Classes="mm-segmented-item"
                                    IsChecked="{Binding IsMonoFontSelected}">
                        <TextBlock Text="{Binding [ReadingFontMono], Source={StaticResource Localization}}" />
                      </ToggleButton>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding [ReadingSizeLabel], Source={StaticResource Localization}}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding [ReadingSizeHint], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                      <Slider Classes="mm-settings-slider"
                              Minimum="14"
                              Maximum="24"
                              TickFrequency="1"
                              IsSnapToTickEnabled="True"
                              Value="{Binding FontSizeSetting, Mode=TwoWay}" />
                      <TextBlock Classes="mm-slider-value"
                                 Text="{Binding FontSizeLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding [ReadingLineHeightLabel], Source={StaticResource Localization}}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding [ReadingLineHeightHint], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                      <Slider Classes="mm-settings-slider"
                              Minimum="1.4"
                              Maximum="2.0"
                              TickFrequency="0.05"
                              IsSnapToTickEnabled="True"
                              Value="{Binding LineHeightSetting, Mode=TwoWay}" />
                      <TextBlock Classes="mm-slider-value"
                                 Text="{Binding LineHeightLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding [ReadingWidthLabel], Source={StaticResource Localization}}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding [ReadingWidthHint], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="mm-segmented"
                            HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="1">
                        <ToggleButton Classes="mm-segmented-item"
                                      IsChecked="{Binding IsNarrowWidthSelected}">
                          <TextBlock Text="{Binding [ReadingWidthNarrow], Source={StaticResource Localization}}" />
                        </ToggleButton>
                        <ToggleButton Classes="mm-segmented-item"
                                      IsChecked="{Binding IsMediumWidthSelected}">
                          <TextBlock Text="{Binding [ReadingWidthMedium], Source={StaticResource Localization}}" />
                        </ToggleButton>
                        <ToggleButton Classes="mm-segmented-item"
                                      IsChecked="{Binding IsWideWidthSelected}">
                          <TextBlock Text="{Binding [ReadingWidthWide], Source={StaticResource Localization}}" />
                        </ToggleButton>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="mm-status"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Bottom"
              Padding="20,0,20,14"
              IsHitTestVisible="False">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="18"
                      VerticalAlignment="Bottom"
                      IsVisible="{Binding ShowsReadingStatus}">
            <TextBlock Text="{Binding WordCountStatusLabel}"
                        FontSize="11"
                        Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding ShowsReadingStatus}" />
            <TextBlock Text="{Binding ReadTimeStatusLabel}"
                        FontSize="11"
                        Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding ShowsReadingStatus}" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="14"
                      VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text="O"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding [StatusOpen], Source={StaticResource Localization}}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text="E"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding EditShortcutLabel}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text=","
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding [StatusPrefs], Source={StaticResource Localization}}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border IsVisible="{Binding IsDragHovering}"
              IsHitTestVisible="False"
              Background="{DynamicResource MmAccentSoftBrush}"
              BorderBrush="{DynamicResource MmAccentBrush}"
              BorderThickness="2"
              CornerRadius="10"
              Margin="12">
        <TextBlock Text="{Binding [DragDropHint], Source={StaticResource Localization}}"
                   FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                   FontSize="14"
                   Foreground="{DynamicResource MmAccentBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

      <Grid IsVisible="{Binding IsDirtyPromptOpen}"
            Background="#66000000">
        <Border Classes="mm-dialog-card"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel>
            <TextBlock Classes="mm-dialog-title"
                       Text="{Binding DirtyPromptTitle}" />
            <TextBlock Classes="mm-dialog-body"
                       Text="{Binding DirtyPromptMessage}" />
            <Border Classes="mm-dialog-error-shell"
                    IsVisible="{Binding HasDirtyPromptError}">
              <TextBlock Classes="mm-dialog-error"
                         Text="{Binding DirtyPromptErrorMessage}" />
            </Border>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,18,0,0">
              <Button Classes="mm-dialog-secondary"
                      Content="{Binding [DirtyPromptCancel], Source={StaticResource Localization}}"
                      Command="{Binding CancelDirtyPromptCommand}" />
              <Button Classes="mm-dialog-secondary"
                      Content="{Binding [DirtyPromptDiscard], Source={StaticResource Localization}}"
                      Command="{Binding ConfirmDirtyDiscardCommand}" />
              <Button Classes="mm-dialog-primary"
                      Content="{Binding [DirtyPromptSave], Source={StaticResource Localization}}"
                      Command="{Binding ConfirmDirtySaveCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Panel>

  </Grid>

</Window>
