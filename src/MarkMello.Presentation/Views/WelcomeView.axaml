<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MarkMello.Presentation.ViewModels"
             mc:Ignorable="d"
             x:Class="MarkMello.Presentation.Views.WelcomeView"
             x:DataType="vm:MainWindowViewModel">

  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                MaxWidth="380">

      <!-- App mark -->
      <Image Source="avares://MarkMello.Presentation/Assets/Images/logo.png"
             Width="160" Height="160"
             HorizontalAlignment="Center"
             Margin="0,0,0,-15" />

      <!-- Logo: "Mark" + accent "Mello", bold, no italic -->
      <TextBlock FontFamily="{DynamicResource MmDocumentSerifFontFamily}"
                 FontSize="44"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource MmTextBrush}">
        <Run Text="Mark" />
        <Run Text="Mello"
             Foreground="{DynamicResource MmAccentBrush}" />
      </TextBlock>

      <TextBlock Text="{Binding WelcomeTagline}"
                 FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource MmTextFaintBrush}"
                 Margin="0,0,0,28" />

      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Classes="welcome-secondary"
                Command="{Binding CreateNewDocumentCommand}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <Path Data="M7 2.5V11.5M2.5 7H11.5"
                  Width="14"
                  Height="14"
                  Stroke="{DynamicResource MmTextSoftBrush}"
                  StrokeThickness="1.5"
                  StrokeLineCap="Round" />
            <TextBlock Text="{Binding WelcomeCreateMd}" />
          </StackPanel>
        </Button>
        <Button Classes="welcome-primary"
                Content="{Binding WelcomeOpenFile}"
                Command="{Binding OpenFileCommand}" />
      </StackPanel>

      <!-- Hotkey hint -->
      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center"
                  Margin="0,28,0,0">
        <Border Classes="kbd">
          <TextBlock Text="Ctrl" FontFamily="{DynamicResource MmDocumentMonoFontFamily}" FontSize="10" />
        </Border>
        <Border Classes="kbd">
          <TextBlock Text="O" FontFamily="{DynamicResource MmDocumentMonoFontFamily}" FontSize="10" />
        </Border>
        <TextBlock Text="{Binding WelcomeDropHint}"
                   FontSize="11"
                   Foreground="{DynamicResource MmTextFaintBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>

    </StackPanel>
  </Grid>

</UserControl>
